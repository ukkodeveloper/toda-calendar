DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
DISCORD_SPRINT_CHANNEL_ID=

# Optional. Defaults to "sprint1" when omitted in /sprint.
DISCORD_DEFAULT_SPRINT_ID=sprint1

# Optional. Relative paths are resolved from the repo root.
DISCORD_BRIDGE_STATE_FILE=.data/discord-bridge-state.json

# Optional. Parallel sprint worktrees default to ~/.codex/worktrees/discord.
DISCORD_WORKTREE_ROOT=
