# Optional locally. When omitted in local development, the web app falls back to
# http://127.0.0.1:3030 on localhost and http://<same-host>:3030 on LAN IP previews.
NEXT_PUBLIC_API_BASE_URL=

# Required for real Supabase OAuth login.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy Supabase anon key fallback is also supported by the app when
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY is omitted.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
