{
  "name": "toda-calendar",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build:packages": "pnpm --filter @workspace/app-core build && pnpm --filter @workspace/contracts build",
    "build": "turbo build",
    "dev": "turbo dev",
    "discord:dev": "pnpm --filter discord-bridge run dev",
    "discord:doctor": "pnpm --filter discord-bridge run doctor",
    "discord:health": "pnpm --filter discord-bridge run health",
    "discord:register": "pnpm --filter discord-bridge run register:commands",
    "lint": "turbo lint",
    "format": "turbo format",
    "preview:vercel": "bash ./scripts/remote/vercel-preview.sh",
    "remote:doctor": "bash ./scripts/remote/doctor.sh",
    "typecheck": "turbo typecheck",
    "test": "turbo test"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
